# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=Cricket
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_PORT=5432

# ── ML Model ──────────────────────────────────────────────────────────────────
# Local path to the pkl file. In production this will be downloaded from GCS.
MODEL_PATH=cricket_match_predictor.pkl

# ── GCP (leave blank for local development) ───────────────────────────────────
GCS_BUCKET_NAME=
GCP_PROJECT_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
